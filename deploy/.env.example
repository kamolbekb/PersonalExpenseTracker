# Copy this to deploy/.env and fill in real values. deploy/.env is git-ignored.
#   cp deploy/.env.example deploy/.env

# --- Postgres (the app's own database; values are wired together in compose) ---
POSTGRES_USER=expense
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=expense

# --- Telegram bot token (from @BotFather; see deploy/README.md step 1) ---
BOT_TOKEN=CHANGE_ME_123456789:AA...

# --- Cloudflare Tunnel token (Zero Trust > Networks > Tunnels > your tunnel) ---
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_tunnel_token

# --- Optional: shared secret to allow POST /internal/refresh (external cron). ---
# Leave blank on an always-on box — the in-process daily scheduler already runs.
RATES_REFRESH_TOKEN=
