# Copy this to deploy/.env and fill in real values. deploy/.env is git-ignored.
#   cp deploy/.env.example deploy/.env
#
# These variable names match the container's environment variables exactly — the
# compose file injects this file via `env_file`, so values are taken literally
# (no quoting/escaping needed even with ';' '=' or '$' in the connection string).

# --- Database: Supabase Postgres connection string (Npgsql key=value format) ---
# Supabase dashboard -> Connect -> Session pooler (port 5432), converted to key=value.
# Keep SSL Mode=Require. Cap Maximum Pool Size well under your Supabase connection
# limit (free tier = 60); 20 is plenty for personal use.
ConnectionStrings__Default=Host=aws-0-eu-central-1.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.<project-ref>;Password=CHANGE_ME_supabase_db_password;SSL Mode=Require;Trust Server Certificate=true;Maximum Pool Size=20

# --- Telegram bot token (from @BotFather; see deploy/README.md step 1) ---
BotToken=CHANGE_ME_123456789:AA...

# --- Cloudflare Tunnel token (Zero Trust > Networks > Tunnels > your tunnel) ---
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_tunnel_token

# --- Optional: shared secret to allow POST /internal/refresh (external cron). ---
# Leave blank on an always-on box — the in-process daily scheduler already runs.
Rates__RefreshToken=
